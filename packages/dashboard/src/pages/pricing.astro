---
import Layout from '../layouts/Layout.astro';

const plans = [
  {
    name: 'Starter',
    price: '$9.99',
    pageviews: '100K',
    priceId: import.meta.env.STRIPE_PRICE_STARTER,
    features: ['Up to 100K pageviews/mo', 'Edge caching', 'One-click deploy'],
  },
  {
    name: 'Growth',
    price: '$24.99',
    pageviews: '500K',
    priceId: import.meta.env.STRIPE_PRICE_GROWTH,
    popular: true,
    features: ['Up to 500K pageviews/mo', 'Edge caching', 'One-click deploy', 'Priority support'],
  },
  {
    name: 'Scale',
    price: '$49.99',
    pageviews: '2M',
    priceId: import.meta.env.STRIPE_PRICE_SCALE,
    features: ['Up to 2M pageviews/mo', 'Edge caching', 'One-click deploy', 'Priority support', 'Custom cache rules'],
  },
];
---

<Layout title="Pricing | ReverseCacheFlow">
  <div class="container">
    <h1>Simple, transparent pricing</h1>
    <p class="subtitle">Save money on Webflow bandwidth. Cancel anytime.</p>

    <div class="plans">
      {plans.map((plan) => (
        <div class:list={['plan', { popular: plan.popular }]}>
          {plan.popular && <div class="badge">Most Popular</div>}
          <h2>{plan.name}</h2>
          <div class="price">
            <span class="amount">{plan.price}</span>
            <span class="period">/month</span>
          </div>
          <p class="pageviews">Up to {plan.pageviews} pageviews</p>
          <ul>
            {plan.features.map((feature) => (
              <li>{feature}</li>
            ))}
          </ul>
          <form method="POST" action="/api/checkout">
            <input type="hidden" name="priceId" value={plan.priceId} />
            <button type="submit" class:list={['btn', { 'btn-primary': plan.popular, 'btn-secondary': !plan.popular }]}>
              Get Started
            </button>
          </form>
        </div>
      ))}
    </div>
  </div>
</Layout>

<style>
  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 80px 24px;
    text-align: center;
  }
  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 8px;
  }
  .subtitle {
    font-size: 1.15rem;
    color: #a3a3a3;
    margin-bottom: 48px;
  }
  .plans {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .plan {
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 12px;
    padding: 32px 24px;
    text-align: left;
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .plan.popular {
    border-color: #2563eb;
    box-shadow: 0 0 24px rgba(37, 99, 235, 0.15);
  }
  .badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: #2563eb;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  h2 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 16px;
  }
  .price {
    margin-bottom: 4px;
  }
  .amount {
    font-size: 2.5rem;
    font-weight: 700;
    color: #fff;
  }
  .period {
    font-size: 1rem;
    color: #737373;
  }
  .pageviews {
    font-size: 0.875rem;
    color: #a3a3a3;
    margin-bottom: 24px;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0 0 24px 0;
    flex: 1;
  }
  li {
    padding: 6px 0;
    font-size: 0.875rem;
    color: #d4d4d4;
  }
  li::before {
    content: '✓ ';
    color: #22c55e;
    font-weight: 700;
  }
  .btn {
    display: block;
    width: 100%;
    padding: 12px;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }
  .btn-primary {
    background: #2563eb;
    color: #fff;
  }
  .btn-primary:hover {
    background: #1d4ed8;
  }
  .btn-secondary {
    background: #262626;
    color: #fff;
    border: 1px solid #404040;
  }
  .btn-secondary:hover {
    background: #333;
  }
  @media (max-width: 768px) {
    .plans {
      grid-template-columns: 1fr;
    }
  }
</style>
