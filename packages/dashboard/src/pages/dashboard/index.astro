---
import Layout from '../../layouts/Layout.astro';
import { UserButton } from '@clerk/astro/components';
---

<Layout title="Dashboard">
  <div class="dashboard">
    <header>
      <h1>ReverseCacheFlow</h1>
      <UserButton />
    </header>

    <main>
      <div class="welcome">
        <h2>Welcome to your dashboard</h2>
        <p>Set up your first domain to start saving bandwidth.</p>
      </div>

      <div class="card">
        <h3>Add a Domain</h3>
        <p>Enter your Webflow site's domain to get started.</p>
        <form id="add-domain">
          <input
            type="text"
            name="hostname"
            placeholder="www.yoursite.com"
            required
          />
          <button type="submit" class="btn btn-primary">Deploy</button>
        </form>
      </div>
    </main>
  </div>

  <style>
    .dashboard {
      max-width: 960px;
      margin: 0 auto;
      padding: 24px;
    }
    header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 0;
      border-bottom: 1px solid #262626;
      margin-bottom: 48px;
    }
    header h1 {
      font-size: 1.25rem;
      color: #fff;
    }
    .welcome {
      margin-bottom: 48px;
    }
    .welcome h2 {
      font-size: 1.75rem;
      color: #fff;
      margin-bottom: 8px;
    }
    .welcome p {
      color: #a3a3a3;
    }
    .card {
      background: #171717;
      border: 1px solid #262626;
      border-radius: 12px;
      padding: 32px;
    }
    .card h3 {
      font-size: 1.25rem;
      color: #fff;
      margin-bottom: 8px;
    }
    .card p {
      color: #a3a3a3;
      margin-bottom: 24px;
    }
    form {
      display: flex;
      gap: 12px;
    }
    input {
      flex: 1;
      padding: 12px 16px;
      border-radius: 8px;
      border: 1px solid #404040;
      background: #0a0a0a;
      color: #fff;
      font-size: 1rem;
    }
    input:focus {
      outline: none;
      border-color: #2563eb;
    }
    .btn {
      padding: 12px 24px;
      border-radius: 8px;
      border: none;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
    }
    .btn-primary {
      background: #2563eb;
      color: #fff;
    }
    .btn-primary:hover {
      background: #1d4ed8;
    }
  </style>
</Layout>
